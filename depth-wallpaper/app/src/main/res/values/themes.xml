<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose draws the UI; this base theme only needs to be a no-action-bar
         Material theme so the splash/window background looks right before Compose starts. -->
    <style name="Theme.DepthWallpaper" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/ic_launcher_background</item>
    </style>
</resources>
