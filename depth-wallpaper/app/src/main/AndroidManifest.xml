<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Live wallpaper support is required to appear in the wallpaper picker. -->
    <uses-feature
        android:name="android.software.live_wallpaper"
        android:required="true" />

    <!-- ML Kit subject segmentation model is downloaded on first use. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".DepthApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DepthWallpaper">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.DepthWallpaper">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The live wallpaper engine that renders the depth composition. -->
        <service
            android:name=".wallpaper.DepthWallpaperService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_WALLPAPER">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/depth_wallpaper" />
        </service>

        <!-- Pre-download the segmentation model when the app is installed. -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="subject_segment" />
    </application>

</manifest>
